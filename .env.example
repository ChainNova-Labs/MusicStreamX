# MusicStreamX Environment Configuration
# Copy this file to .env and update with your values

# Application
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://musicstreamx:musicstreamx123@localhost:5432/musicstreamx
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
BCRYPT_ROUNDS=12

# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_CONTRACT_ADDRESS=your-contract-address-here
STELLAR_SECRET_KEY=your-stellar-secret-key-here
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# IPFS Configuration
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080
IPFS_PROJECT_ID=your-ipfs-project-id
IPFS_PROJECT_SECRET=your-ipfs-project-secret

# Frontend URLs
FRONTEND_URL=http://localhost:3100
MUSIC_PLAYER_URL=http://localhost:3100
ARTIST_DASHBOARD_URL=http://localhost:3200
FAN_PORTAL_URL=http://localhost:3300
NFT_MARKETPLACE_URL=http://localhost:3400
LIVE_EVENTS_URL=http://localhost:3500
GOVERNANCE_UI_URL=http://localhost:3600

# Music Platform Configuration
PLATFORM_FEE_PERCENTAGE=500
MIN_ROYALTY_PER_STREAM=1000
MAX_TRACK_DURATION=3600
DEFAULT_TRACK_DURATION=300
MIN_STREAM_REWARD=1000
MAX_STREAM_REWARD=100000

# NFT Configuration
MIN_NFT_SUPPLY=1
MAX_NFT_SUPPLY=10000
DEFAULT_NFT_ROYALTY=1000
MAX_NFT_ROYALTY=5000
MIN_MINT_PRICE=10000000
MAX_MINT_PRICE=10000000000

# Fan Token Configuration
MIN_FAN_TOKEN_SUPPLY=1000000
MAX_FAN_TOKEN_SUPPLY=10000000000
DEFAULT_FAN_TOKEN_SUPPLY=1000000000
MIN_ENGAGEMENT_SCORE=0
MAX_ENGAGEMENT_SCORE=10000

# Streaming Configuration
STREAM_QUALITY_STANDARD=100
STREAM_QUALITY_HIGH=150
STREAM_QUALITY_LOSSLESS=200
STREAM_QUALITY_MASTER=300
MAX_CONCURRENT_STREAMS=1000

# Live Streaming Configuration
WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302
WEBRTC_TURN_SERVER=turn:your-turn-server.com:3478
WEBRTC_TURN_USERNAME=your-turn-username
WEBRTC_TURN_CREDENTIAL=your-turn-credential
MAX_LIVE_EVENT_ATTENDEES=10000
LIVE_EVENT_DURATION=7200

# Governance Configuration
VOTING_PERIOD=604800
QUORUM_REQUIREMENT=1000
PROPOSAL_THRESHOLD=500
MIN_VOTING_POWER=1000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=9091

# External Services
EMAIL_SERVICE_API_KEY=your-email-service-api-key
NOTIFICATION_SERVICE_URL=https://api.notificationservice.com
PUSH_NOTIFICATION_VAPID_PUBLIC_KEY=your-vapid-public-key
PUSH_NOTIFICATION_VAPID_PRIVATE_KEY=your-vapid-private-key
PUSH_NOTIFICATION_VAPID_EMAIL=your-email@example.com

# Development
ENABLE_CORS=true
ENABLE_DEBUG_LOGGING=true
ENABLE_SWAGGER=true

# Production (uncomment for production)
# NODE_ENV=production
# STELLAR_NETWORK=public
# STELLAR_HORIZON_URL=https://horizon.stellar.org
# ENABLE_DEBUG_LOGGING=false

# Smart Contract Addresses
MUSIC_NFT_CONTRACT=your-music-nft-contract-address
STREAMING_CONTRACT=your-streaming-contract-address
GOVERNANCE_CONTRACT=your-governance-contract-address
FAN_TOKEN_CONTRACT=your-fan-token-contract-address

# API Keys
COINGECKO_API_KEY=your-coingecko-api-key
STELLAR_EXPERT_API_KEY=your-stellar-expert-api-key

# WebSocket Configuration
WEBSOCKET_PORT=3005
WEBSOCKET_PATH=/socket.io

# Cache Configuration
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# File Upload Configuration
MAX_FILE_SIZE=104857600
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/flac,audio/ogg
UPLOAD_DIR=uploads

# Collaboration Configuration
MIN_COLLABORATORS=1
MAX_COLLABORATORS=10
MIN_COLLABORATOR_SPLIT=500
MAX_COLLABORATOR_SPLIT=5000

# Quality Configuration
QUALITY_STANDARD=standard
QUALITY_HIGH=high
QUALITY_LOSSLESS=lossless
QUALITY_MASTER=master

# Revenue Distribution
PLATFORM_FEE_SHARE=5000
ARTIST_FEE_SHARE=4000
TREASURY_SHARE=1000

# Analytics Configuration
ANALYTICS_ENABLED=true
USER_BEHAVIOR_TRACKING=true
PERFORMANCE_MONITORING=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Security Configuration
ENABLE_RATE_LIMITING=true
ENABLE_CSP=true
ENABLE_HSTS=true
CORS_ALLOWED_ORIGINS=http://localhost:3100,http://localhost:3200,http://localhost:3300
